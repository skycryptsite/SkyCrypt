{
  "name": "skycrypt-frontend",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/SkyCryptWebsite/SkyCryptv2.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "dotenv -e .env.development -- vite build",
    "preview": "vite preview",
    "preview:dev": "dotenv -e .env.development -- vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "runbuild": "node ./build",
    "test": "vitest --ui && pnpm run test:unit -- --run",
    "test:ui": "pnpm run test:unit -- --ui",
    "lint": "prettier --check . && eslint . && pnpm check",
    "format": "prettier --write .",
    "prepare": "svelte-kit sync || echo ''",
    "test:unit": "vitest",
    "changelog": "changelogen",
    "changelog:bump": "changelogen --bump",
    "release": "changelogen --release --push"
  },
  "devDependencies": {
    "@date-fns/tz": "^1.4.1",
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.38.0",
    "@lucide/svelte": "^0.546.0",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@sveltejs/adapter-node": "^5.4.0",
    "@sveltejs/kit": "^2.47.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.1.15",
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.9.1",
    "@types/relaxed-json": "^1.0.4",
    "@types/upng-js": "^2.1.5",
    "@vitest/browser": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "bits-ui": "^2.14.0",
    "changelogen": "^0.6.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.12.5",
    "formsnap": "^2.0.1",
    "globals": "^16.4.0",
    "ky": "^1.12.0",
    "numerable": "^0.3.15",
    "orval": "^7.14.0",
    "paneforge": "^1.0.2",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "pretty-ms": "^9.3.0",
    "runed": "^0.35.1",
    "skinview3d": "^3.4.1",
    "svelte": "^5.41.1",
    "svelte-check": "^4.3.3",
    "svelte-dnd-action": "^0.9.65",
    "svelte-interactions": "^0.2.0",
    "svelte-persisted-store": "^0.12.0",
    "svelte-preprocess": "^6.0.3",
    "svelte-seo": "1.6.1",
    "svelte-sonner": "^1.0.5",
    "svelte-tiny-virtual-list": "^3.0.1",
    "sveltekit-superforms": "^2.28.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.15",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^7.1.11",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^3.2.4",
    "vitest-browser-svelte": "^1.1.0",
    "webdriverio": "^9.20.0",
    "zod": "^4.1.12"
  },
  "dependencies": {
    "@sentry/sveltekit": "^10.20.0"
  },
  "engines": {
    "node": "^22",
    "pnpm": "^10",
    "deno": "forbidden, use node instead",
    "npm": "forbidden, use pnpm instead",
    "yarn": "forbidden, use pnpm instead",
    "bun": "forbidden, use pnpm instead"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "@tailwindcss/oxide",
      "esbuild",
      "svelte-preprocess"
    ]
  }
}
